{
  "name": "neo-fala-amazonia",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @neo-fala-amazonia/backend\" \"npm run dev --workspace @neo-fala-amazonia/frontend\"",
    "dev:backend": "npm run dev --workspace @neo-fala-amazonia/backend",
    "dev:frontend": "npm run dev --workspace @neo-fala-amazonia/frontend",
    "build": "npm run build --workspace @neo-fala-amazonia/backend && npm run build --workspace @neo-fala-amazonia/frontend",
    "lint": "npm run lint --workspace @neo-fala-amazonia/backend && npm run lint --workspace @neo-fala-amazonia/frontend",
    "prisma:generate": "npm run prisma:generate --workspace @neo-fala-amazonia/backend",
    "prisma:push": "npm run prisma:push --workspace @neo-fala-amazonia/backend",
    "prisma:seed": "npm run prisma:seed --workspace @neo-fala-amazonia/backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
